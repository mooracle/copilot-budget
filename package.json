{
  "name": "copilot-budget",
  "displayName": "Copilot Budget",
  "description": "Track GitHub Copilot token usage and optionally append AI budget info to git commit messages",
  "version": "0.6.0",
  "publisher": "mooracle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mooracle/copilot-budget"
  },
  "bugs": {
    "url": "https://github.com/mooracle/copilot-budget/issues"
  },
  "homepage": "https://github.com/mooracle/copilot-budget#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "budget",
    "token",
    "usage",
    "tracking",
    "ai",
    "github-copilot"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilot-budget.showStats",
        "title": "Copilot Budget: Show Token Stats"
      },
      {
        "command": "copilot-budget.resetTracking",
        "title": "Copilot Budget: Reset Tracking"
      },
      {
        "command": "copilot-budget.installHook",
        "title": "Copilot Budget: Install Commit Hook"
      },
      {
        "command": "copilot-budget.uninstallHook",
        "title": "Copilot Budget: Uninstall Commit Hook"
      },
      {
        "command": "copilot-budget.showDiagnostics",
        "title": "Copilot Budget: Show Diagnostics"
      }
    ],
    "configuration": {
      "title": "Copilot Budget",
      "properties": {
        "copilot-budget.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Copilot Budget token usage tracking"
        },
        "copilot-budget.commitHook.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Automatically install the prepare-commit-msg hook to append AI budget info to commits"
        },
        "copilot-budget.commitHook.trailers.estimatedCost": {
          "type": [
            "string",
            "boolean"
          ],
          "default": false,
          "markdownDescription": "Opt-in git trailer key for estimated USD cost (e.g. `\"Copilot-Est-Cost\"`). Disabled by default; enable for users who want USD in commit history. AI Credits is the primary unit."
        },
        "copilot-budget.commitHook.trailers.aiCredits": {
          "type": [
            "string",
            "boolean"
          ],
          "default": "Copilot-AI-Credits",
          "markdownDescription": "Git trailer key for total AI Credits (1 AIC = $0.01, plan-invariant). Set to `false` to disable."
        },
        "copilot-budget.commitHook.trailers.aiCreditsPerModel": {
          "type": [
            "string",
            "boolean"
          ],
          "default": false,
          "markdownDescription": "Git trailer key for per-model AI Credits breakdown. Set to a string (e.g. `\"Copilot-AI-Credits-Models\"`) to enable."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "package": "npx @vscode/vsce package",
    "update-rates": "bash scripts/update-rates.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "sql.js": "^1.14.0"
  }
}
